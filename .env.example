# ============================================================
# 백엔드 전용 환경변수 (알바페이 프론트엔드 리포의 .env에서 이전됨)
# ============================================================

# -- Supabase --
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -- 국세청 사업자 상태 조회 API --
NTS_API_KEY=

# -- Toss OAuth --
TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im

# mTLS 클라이언트 인증서: PEM 파일 내용을 base64 인코딩한 값
# base64 명령어: base64 -i toss-client.crt | tr -d '\n'
# 개인키는 PKCS8("BEGIN PRIVATE KEY") 형식만 지원한다.
# PKCS1("BEGIN RSA PRIVATE KEY")이면 먼저 변환할 것:
#   openssl pkcs8 -topk8 -nocrypt -in toss-client.key -out toss-client.pkcs8.key
TOSS_MTLS_CERT=
TOSS_MTLS_KEY=
TOSS_MTLS_CA=

# Toss 필드 복호화 (AES-256-GCM)
TOSS_LOGIN_DECRYPTION_KEY=
TOSS_LOGIN_DECRYPTION_AAD=

# 세션 쿠키 서명 (HMAC-SHA256)
TOSS_SESSION_SECRET=

# Toss 콜백 Basic 인증
TOSS_CALLBACK_BASIC_USER=
TOSS_CALLBACK_BASIC_PASSWORD=

# -- CORS: 프론트엔드 배포 도메인 (콤마로 여러 개 지정 가능, * 사용 금지) --
CORS_ALLOWED_ORIGINS=http://localhost:5173
